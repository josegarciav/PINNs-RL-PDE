    "### 7c  Space–Time Heat Map"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "a1b2c3d4-0017-4017-8017-000000000017",
   "metadata": {},
   "outputs": [
    {
     "data": {
